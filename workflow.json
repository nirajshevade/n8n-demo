            "Email": "={{ $json.candidateEmail }}",
            "Score": "={{ $json.score }}",
            "Status": "={{ $json.score > 75 ? 'Selected' : 'Rejected' }}",
            "ProcessedAt": "={{ $now.toISO() }}"
          }
        },
        "options": {}
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "",
          "name": "Google Sheets account"
        }
      }
    }
